  classDef model fill:#fde7e9,stroke:#b8232f,color:#7a1f2b,stroke-width:2px;
  classDef good  fill:#e6f4ea,stroke:#137333,color:#0b5e26,stroke-width:1.5px;
  classDef warn  fill:#fff3e0,stroke:#e08600,color:#8a5200,stroke-width:1.5px;
  classDef store fill:#eceff1,stroke:#5f7d8c,color:#324a54,stroke-width:1.5px;
  class A,C proc;
  class B inp;
  class D model;
